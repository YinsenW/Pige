{
  "name": "@pige/desktop",
  "productName": "Pige",
  "version": "0.0.0",
  "private": true,
  "description": "Pige local-first personal knowledge Agent desktop application.",
  "author": "YinsenW",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node ../../scripts/build/macos-vision-ocr-helper.mjs && node ../../scripts/build/macos-speech-helper.mjs && electron-vite dev",
    "build": "node ../../scripts/build/macos-vision-ocr-helper.mjs && node ../../scripts/build/macos-speech-helper.mjs && electron-vite build",
    "package:dir:mac:arm64": "node ../../scripts/release/run-electron-builder.mjs --platform=macos --arch=arm64",
    "package:dir:win:x64": "node ../../scripts/release/run-electron-builder.mjs --platform=windows --arch=x64",
    "smoke:electron-undici-transport": "electron scripts/electron-undici-transport-smoke.mjs",
    "smoke:electron-pi-agent": "electron scripts/electron-pi-agent-runtime-smoke.mjs",
    "smoke:electron-persisted-provider": "node scripts/electron-persisted-provider-canary.mjs",
    "smoke:electron-unified-agent-roundtrip": "node scripts/electron-unified-agent-roundtrip-smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.80.7",
    "@earendil-works/pi-ai": "0.80.7",
    "@mozilla/readability": "0.6.0",
    "@napi-rs/canvas": "1.0.2",
    "@pige/contracts": "0.0.0",
    "@pige/domain": "0.0.0",
    "@pige/markdown": "0.0.0",
    "@pige/schemas": "0.0.0",
    "fast-xml-parser": "5.10.1",
    "jsdom": "29.1.1",
    "lucide-react": "1.17.0",
    "mammoth": "1.12.0",
    "pdfjs-dist": "6.1.200",
    "proper-lockfile": "4.1.2",
    "react": "19.2.8",
    "react-dom": "19.2.7",
    "tar": "7.5.20",
    "undici": "8.7.0",
    "yauzl": "3.4.0",
    "yazl": "3.3.1"
  }
}
