{
  "schemaVersion": 1,
  "id": "office_openxml",
  "engines": [
    { "id": "mammoth", "version": "1.12.0", "sourceKinds": ["docx_file"] },
    { "id": "fast-xml-parser", "version": "5.9.3", "sourceKinds": ["docx_file", "pptx_file"] },
    { "id": "yauzl", "version": "3.4.0", "sourceKinds": ["docx_file", "pptx_file"] }
  ],
  "capabilities": [
    "semantic_text",
    "headings",
    "lists",
    "tables",
    "links",
    "slide_order",
    "speaker_notes",
    "media_references",
    "fragment_locators",
    "ocr_handoff"
  ],
  "executionBoundary": "node_worker_thread",
  "networkAccess": false,
  "externalFileAccess": false,
  "hiddenDownloads": false,
  "limits": {
    "maxBytes": 104857600,
    "maxEntries": 10000,
    "maxUncompressedBytes": 536870912,
    "maxXmlEntryBytes": 10485760,
    "maxSelectedXmlBytes": 134217728,
    "maxSlides": 2000,
    "maxTextCharacters": 10000000,
    "timeoutMs": 60000
  }
}
