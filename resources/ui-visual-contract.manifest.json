{
  "schemaVersion": 1,
  "owner": "docs/UI_PROTOTYPE.md#162-pige-visual-system",
  "rendererStylesheet": "apps/desktop/src/renderer/src/styles/app.css",
  "referenceBoundary": "clean-room-observation-only",
  "requiredCustomProperties": {
    "--space": "4px",
    "--canvas": "#ffffff",
    "--surface": "#ffffff",
    "--text-primary": "#202322",
    "--radius-md": "8px",
    "--radius-xl": "12px",
    "--radius-2xl": "16px",
    "--radius-3xl": "20px",
    "--radius-composer": "22px",
    "--duration-fast": "150ms",
    "--duration-relaxed": "300ms",
    "--ease-enter": "cubic-bezier(0.19, 1, 0.22, 1)",
    "--home-pane-min": "360px",
    "--home-pane-default": "420px",
    "--home-pane-max": "420px",
    "--library-pane-min": "240px",
    "--library-pane-default": "280px",
    "--library-pane-max": "320px",
    "--reader-pane-min": "560px",
    "--reader-pane-default": "720px",
    "--reader-pane-max": "960px",
    "--reader-prose-max": "720px",
    "--agent-pane-min": "360px",
    "--agent-pane-default": "400px",
    "--agent-pane-max": "440px"
  },
  "requiredRuleDeclarations": [
    { "selector": ".topbar", "property": "height", "value": "46px" },
    { "selector": ".sidebar", "property": "width", "value": "clamp(var(--library-pane-min), var(--library-pane-default), var(--library-pane-max))" },
    { "selector": ".nav-item", "property": "min-height", "value": "30px" },
    { "selector": ".composer", "property": "width", "value": "min(100%, var(--home-pane-max))" },
    { "selector": ".composer", "property": "border-radius", "value": "var(--radius-composer)" },
    { "selector": ".toolbar .round-button", "property": "width", "value": "28px" },
    { "selector": ".markdown-body", "property": "width", "value": "min(100%, var(--reader-prose-max))" },
    { "selector": ".markdown-body", "property": "line-height", "value": "1.625" }
  ],
  "requiredStylesheetMarkers": [
    "@media (prefers-color-scheme: dark)",
    "@media (prefers-reduced-transparency: reduce)",
    "@media (prefers-reduced-motion: reduce)",
    "@media (max-width: 839px)",
    "@media (min-width: 840px) and (max-width: 1199px)",
    "@media (min-width: 1200px) and (max-width: 1439px)",
    "@media (min-width: 1440px)"
  ],
  "captureMatrix": {
    "viewports": [
      { "id": "compact-narrow", "width": 420, "height": 720, "scaleFactor": 2 },
      { "id": "compact-tall", "width": 520, "height": 900, "scaleFactor": 2 },
      { "id": "expanded", "width": 1180, "height": 820, "scaleFactor": 2 },
      { "id": "reading-wide", "width": 1440, "height": 960, "scaleFactor": 2 }
    ],
    "locales": ["zh-Hans", "en", "de", "ja"],
    "themes": ["light", "dark"],
    "requiredStates": [
      "first-run",
      "home-empty",
      "home-typing",
      "home-files-attached",
      "home-processing",
      "home-retrieval-answer",
      "home-error-retry",
      "whole-window-drop",
      "sidebar-expanded",
      "library-populated",
      "note-reader",
      "settings-models",
      "settings-models-preset",
      "settings-models-custom",
      "settings-models-provider",
      "confirmation-required",
      "permission-dialog"
    ]
  },
  "baselinePolicy": {
    "root": "artifacts/ui-visual-baselines",
    "filePattern": "<platform>/<theme>/<locale>/<viewport>/<state>.png",
    "metadataPattern": "<platform>/<theme>/<locale>/<viewport>/<state>.json",
    "syntheticDataOnly": true,
    "pixelDifferenceReviewThreshold": 0.005,
    "baselineUpdateRequiresHumanReview": true,
    "baselineUpdateRequiresRationale": true,
    "releasePlatforms": ["macos-arm64", "windows-x64"]
  }
}
